# ═══════════════════════════════════════════════════════════════
# TradingTP Bot — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# LINE Official Account
# ─────────────────────────────────────────────
# Channel Secret / Access Token จาก LINE Developers Console > Messaging API
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# LINE User ID ของ Admin (ตัวคุณเอง)
# วิธีหา: ส่งข้อความหา Bot แล้วดู log หรือใช้ LINE Developers Console
ADMIN_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# เปิด/ปิด LINE ทั้งหมด (webhook, push, reply) โดยไม่ต้องลบโค้ด
# false = ปิด (บอทใช้ Facebook เป็นหลัก) | true = เปิดใช้งาน LINE
LINE_ENABLED=false

# (ออปชัน) ส่ง Daily Signal เข้ากลุ่ม LINE — Group ID ขึ้นต้นด้วย C
# ได้มาอัตโนมัติเมื่อเพิ่ม Bot เข้ากลุ่ม (Bot จะส่ง Group ID มาให้ admin ทาง FB)
LINE_BROADCAST_GROUP_ID=

# ─────────────────────────────────────────────
# Google Gemini — ใช้วิเคราะห์กราฟ/สร้างสัญญาณ
# ─────────────────────────────────────────────
# API key จาก https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
# ใช้ service_role key (ไม่ใช่ anon/publishable key)
#   Project Settings → API Keys → "service_role" (หรือ sb_secret_...)
# service_role bypass Row-Level Security ทำให้บอททำงานได้แม้เปิด RLS แล้ว
# ⚠️ ห้าม leak key นี้เด็ดขาด — มีสิทธิ์เต็มในฐานข้อมูล และห้ามใช้ฝั่ง client
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ─────────────────────────────────────────────
# Exness Affiliate
# ─────────────────────────────────────────────
# Affiliate Link ของคุณ (แนบใน signal ทุกวัน)
EXNESS_AFFILIATE_LINK=https://one.exnessonelink.com/a/lut0605b6n

# ─────────────────────────────────────────────
# Facebook Messenger (ออปชัน — เว้นว่างเพื่อปิด)
# ─────────────────────────────────────────────
# Page Access Token: Facebook Developer Console > App > Messenger > Access Tokens
FB_PAGE_ACCESS_TOKEN=

# App Secret: Facebook Developer Console > App > Settings > Basic
FB_APP_SECRET=

# App ID: Facebook Developer Console > App > Settings > Basic
# ใช้ตั้ง Primary Receiver ผ่าน /setup/facebook endpoint
FB_APP_ID=

# สตริงสุ่มใดก็ได้ที่คุณตั้งเอง ใช้ตอน register webhook กับ Facebook
FB_VERIFY_TOKEN=my_random_verify_token_here

# Facebook PSID ของ Admin (ตัวคุณเอง)
# วิธีหา: ดูจาก log เมื่อส่งข้อความหา Page ครั้งแรก หรือดูใน Supabase (user_id ของคุณ)
ADMIN_FB_PSID=

# ─────────────────────────────────────────────
# Gmail IMAP Auto-Verify (ออปชัน — เว้นว่างเพื่อปิด)
# ─────────────────────────────────────────────
# Gmail address ที่รับ email แจ้งเตือนจาก Exness
GMAIL_ADDRESS=your@gmail.com

# Gmail App Password (ไม่ใช่รหัสผ่านปกติ — 16 ตัวอักษร)
# สร้างที่: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
# Railway จะ set PORT ให้อัตโนมัติ (ไม่ต้องตั้งบน Railway)
PORT=8000
