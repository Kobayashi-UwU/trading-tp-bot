# LINE Official Account
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# LINE User ID ของ Admin (ตัวคุณเอง)
# วิธีหา: ส่งข้อความหา Bot แล้วดู log หรือใช้ LINE Developer Console
ADMIN_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Affiliate Link ของคุณ (ใส่ใน signal ทุกวัน)
IUX_AFFILIATE_LINK=https://iux.com/register?ref=TRADINGTP

# ─────────────────────────────────────────────
# Facebook Messenger (optional — leave blank to disable)
# ─────────────────────────────────────────────
# Page Access Token จาก Facebook Developer Console > Your App > Messenger > Access Tokens
FB_PAGE_ACCESS_TOKEN=EAXXXXXXXX

# App Secret จาก Facebook Developer Console > Your App > Settings > Basic
FB_APP_SECRET=

# App ID จาก Facebook Developer Console > Your App > Settings > Basic
# ใช้สำหรับตั้ง Primary Receiver ผ่าน /setup/facebook endpoint
FB_APP_ID=

# สตริงสุ่มใดก็ได้ที่คุณตั้งเอง ใช้ตอน register webhook กับ Facebook
FB_VERIFY_TOKEN=my_random_verify_token_here

# ─────────────────────────────────────────────
# Gmail IMAP Auto-Verify (optional — leave blank to disable)
# ─────────────────────────────────────────────
# Gmail address ที่รับ email แจ้งเตือนจาก IUX
GMAIL_ADDRESS=your@gmail.com

# Gmail App Password (ไม่ใช่รหัสผ่านปกติ)
# วิธีสร้าง: Google Account → Security → 2-Step Verification → App passwords
# → Create → ตั้งชื่อ "TradingTP Bot" → copy 16-char password
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# PORT (Railway จะ set ให้อัตโนมัติ)
PORT=8000